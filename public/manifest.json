{
  "manifest_version": 3,
  "name": "Tabbit: Tab Closer & Organizer",
  "version": "0.1.2",
  "description": "Finally close all your open tabs. Tab closer & tab manager with hotkeys, bulk close, AI grouping, auto-close, and tab sorting.",
  "permissions": [
    "tabs",
    "scripting",
    "bookmarks",
    "tabGroups",
    "activeTab",
    "debugger",
    "alarms",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Start Tab Triage",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}